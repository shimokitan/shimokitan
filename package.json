{
    "name": "shimokitan",
    "private": true,
    "packageManager": "bun@1.3.9",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "sync-env": "bun -e \"import fs from 'node:fs'; fs.copyFileSync('.env.local', 'apps/main/.env.local')\"",
        "build": "bun run sync-env && bun x turbo build",
        "dev": "bun run sync-env && bun x turbo dev",
        "lint": "bun run sync-env && bun x turbo lint",
        "type-check": "bun run sync-env && bun x turbo type-check",
        "format": "prettier --write \"**/*.{ts,tsx,md}\""
    },
    "devDependencies": {
        "@types/node": "^20",
        "prettier": "^3.4.2",
        "turbo": "^2.8.13",
        "typescript": "^5.7.3"
    }
}