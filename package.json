{
    "name": "shimokitan",
    "private": true,
    "packageManager": "bun@1.3.9",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "build": "turbo build",
        "dev": "turbo dev",
        "lint": "turbo lint",
        "type-check": "turbo type-check",
        "format": "prettier --write \"**/*.{ts,tsx,md}\"",
        "deploy:main": "turbo run deploy:cf --filter=main"
    },
    "devDependencies": {
        "@opennextjs/cloudflare": "^1.16.5",
        "prettier": "^3.4.2",
        "turbo": "^2.3.3",
        "typescript": "^5.7.3",
        "wrangler": "^4.65.0"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.992.0",
        "@aws-sdk/s3-request-presigner": "^3.992.0"
    }
}