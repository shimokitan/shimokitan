{
    "$schema": "https://turbo.build/schema.json",
    "globalEnv": [
        "DATABASE_URL",
        "RESEND_API_KEY",
        "NEON_AUTH_BASE_URL",
        "NEON_AUTH_COOKIE_SECRET",
        "R2_ENDPOINT",
        "R2_ACCESS_KEY_ID",
        "R2_SECRET_ACCESS_KEY",
        "R2_BUCKET_NAME",
        "NEXT_PUBLIC_R2_DOMAIN"
    ],
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                ".next/**",
                "!.next/cache/**",
                "dist/**"
            ]
        },
        "lint": {
            "dependsOn": [
                "^lint"
            ]
        },
        "type-check": {
            "dependsOn": [
                "^type-check"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "build:cf": {
            "dependsOn": [
                "^build",
                "build"
            ],
            "outputs": [
                ".open-next/**"
            ]
        },
        "deploy:cf": {
            "dependsOn": [
                "build:cf"
            ],
            "cache": false
        }
    }
}